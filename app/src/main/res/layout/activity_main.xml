<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rw_bg"
    android:orientation="vertical"
    tools:context=".controls.MainActivity">

    <FrameLayout
        android:id="@+id/renderHost"
        android:layout_width="match_parent"
        android:layout_height="@dimen/preview_height"
        android:background="#000000">

        <ImageButton
            android:id="@+id/castOverlayButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|end"
            android:layout_margin="14dp"
            android:background="@android:color/transparent"
            android:backgroundTint="#B0000000"
            android:padding="10dp"
            android:src="@drawable/ic_cast_overlay"
            android:tint="#FFFFFF"
            android:visibility="gone" />

        <Button
            android:id="@+id/fullscreenOverlayButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            android:backgroundTint="#B0000000"
            android:text="Fullscreen"
            android:textColor="#FFFFFF"
            android:visibility="gone" />
    </FrameLayout>

    <ScrollView
        android:id="@+id/controlsScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RaveWave Controls"
                android:textColor="@color/rw_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/rw_accent"
                android:textSize="12sp"
                tools:text="Idle" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/micButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/source_mic" />

                    <Button
                        android:id="@+id/fileButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/source_file" />

                    <Button
                        android:id="@+id/captureButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/source_capture" />

                    <Button
                        android:id="@+id/playPauseButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/play_pause" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/fileNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/rw_text"
                android:textSize="12sp"
                tools:text="No file selected" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="FX Intensity"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/intensitySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Speed"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/speedSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="60" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tile Count"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/tileSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="4"
                android:progress="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Symmetry Segments"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/symmetrySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="8"
                android:progress="2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Colorize"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/colorModeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/randomizeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Randomize" />

                <Button
                    android:id="@+id/evolveButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Evolve: Off" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Base Layers"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/baseLayersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sacred Geometry"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/sacredLayersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Extra Layers"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/extraLayersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Music Objects"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/musicLayersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Post FX"
                android:textColor="@color/rw_text"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/postFxContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="28dp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
